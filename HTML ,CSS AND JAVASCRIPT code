        function bookDoctor(btn) {
            btn.innerHTML = "✓ Booked!";
            btn.style.backgroundColor = "#10b981";
            setTimeout(() => {
                alert("🎉 Appointment confirmed for tomorrow at 10:00 AM!\n\nDoctor will call you shortly.");
                btn.innerHTML = "Book Now";
                btn.style.backgroundColor = "";
            }, 800);
        }
        
        function fakeLogin() {
            alert("✅ Logged in successfully! Welcome back to SehatConnect.");
            document.getElementById('login-modal').classList.add('hidden');
        }
        
        // Keyboard support for search
        document.getElementById('search-input').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') performSearch();
